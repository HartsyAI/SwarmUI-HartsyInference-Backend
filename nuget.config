<?xml version="1.0" encoding="utf-8"?>
<!-- Adds a local folder feed for locally-packed HartsyInference engine builds (dotnet pack
     -p:VersionSuffix=alpha.N-local -o ~/.local/share/hartsy-local-nuget) so the extension can
     pin engine changes that aren't published to nuget.org yet. nuget.org stays available for
     all other dependencies. -->
<configuration>
  <packageSources>
    <add key="hartsy-local" value="/home/hartsy/.local/share/hartsy-local-nuget" />
  </packageSources>
</configuration>
